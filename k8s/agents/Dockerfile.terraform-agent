# ─────────────────────────────────────────────────────────────────────────────
# k8s/agents/Dockerfile.terraform-agent
# Imagen custom para los agentes Jenkins que ejecutan Terraform.
# Incluye: Terraform, AWS CLI v2, tflint, kubectl, git, jq, curl.
#
# Build:
#   docker build -f k8s/agents/Dockerfile.terraform-agent \
#     -t acme/jenkins-terraform-agent:1.7.5 .
#   docker push acme/jenkins-terraform-agent:1.7.5
# ─────────────────────────────────────────────────────────────────────────────

FROM jenkins/inbound-agent:3256.v88a_f6e922152-1-jdk21

USER root

# ── Versiones pinadas para reproducibilidad ──────────────────────────────────
ARG TERRAFORM_VERSION=1.7.5
ARG TFLINT_VERSION=0.50.3
ARG KUBECTL_VERSION=1.29.3
ARG AWSCLI_VERSION=2.15.30

# ── Dependencias base ────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        unzip \
        git \
        jq \
        python3 \
        python3-pip \
        gnupg \
        lsb-release \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Terraform ────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip" \
        -o /tmp/terraform.zip \
    && unzip /tmp/terraform.zip -d /usr/local/bin/ \
    && rm /tmp/terraform.zip \
    && terraform version

# ── AWS CLI v2 ───────────────────────────────────────────────────────────────
RUN curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64-${AWSCLI_VERSION}.zip" \
        -o /tmp/awscliv2.zip \
    && unzip /tmp/awscliv2.zip -d /tmp/ \
    && /tmp/aws/install \
    && rm -rf /tmp/aws /tmp/awscliv2.zip \
    && aws --version

# ── tflint ───────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://github.com/terraform-linters/tflint/releases/download/v${TFLINT_VERSION}/tflint_linux_amd64.zip" \
        -o /tmp/tflint.zip \
    && unzip /tmp/tflint.zip -d /usr/local/bin/ \
    && rm /tmp/tflint.zip \
    && tflint --version

# ── kubectl ──────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/amd64/kubectl" \
        -o /usr/local/bin/kubectl \
    && chmod +x /usr/local/bin/kubectl \
    && kubectl version --client

# ── terraform-docs (genera documentación automática) ────────────────────────
RUN curl -fsSL "https://github.com/terraform-docs/terraform-docs/releases/download/v0.17.0/terraform-docs-v0.17.0-linux-amd64.tar.gz" \
        | tar -xz -C /usr/local/bin/ \
    && terraform-docs --version

# ── Caché de providers Terraform (acelera builds) ───────────────────────────
ENV TF_PLUGIN_CACHE_DIR=/home/jenkins/.terraform.d/plugin-cache
RUN mkdir -p ${TF_PLUGIN_CACHE_DIR}

# ── Volver al usuario jenkins ────────────────────────────────────────────────
USER jenkins

# ── Pre-calentar providers AWS más usados ───────────────────────────────────
RUN mkdir -p /tmp/tf-warm \
    && cat > /tmp/tf-warm/main.tf << 'EOF'
terraform {
  required_providers {
    aws = { source = "hashicorp/aws"; version = "~> 5.40" }
  }
}
EOF
RUN cd /tmp/tf-warm && terraform init && rm -rf /tmp/tf-warm

WORKDIR /home/jenkins
